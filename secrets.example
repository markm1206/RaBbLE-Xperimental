# ─────────────────────────────────────────────────────────────────────────────
# RaBbLE Secrets — NEVER commit this file.
# Copy to .secrets, fill in values, then run:
#   ./harness/env_gen.sh             → write services/intelligence/.env
#   ./harness/deploy.sh              → push to Railway and deploy
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Providers (at least one required) ─────────────────────────────────────
# Groq: https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate a secret: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Admin API key — grants unlimited access, bypasses rate limits (keep secret)
RABBLE_ADMIN_KEY=
