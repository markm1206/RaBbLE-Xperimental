# ── Secrets — NEVER commit ────────────────────────────────────────────────────
.secrets
*.pem
*.key

# ── Generated env files ───────────────────────────────────────────────────────
services/*/.env
.env
.env.local
.env.remote

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# ── Runtime artifacts ─────────────────────────────────────────────────────────
services/*/audit.jsonl
audit.jsonl
*.log

# ── Railway local config (project-specific, not portable) ────────────────────
services/*/.railway/
.railway_last_deploy_*

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
