# ── Required ───────────────────────────────────────────────────────────────────
JWT_SECRET=generate-with-python-c-import-secrets-print-secrets-token-hex-32

# At least one LLM provider key is required
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ── Auth ───────────────────────────────────────────────────────────────────────
# Admin API key — bypasses rate limits, full access (keep secret)
RABBLE_ADMIN_KEY=

# Demo mode — allow unauthenticated access as a guest (free tier limits apply)
# Set to "true" for the frontend demo; leave unset for production
DEMO_MODE=false

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or "*" for open access
FRONTEND_URL=http://localhost:8080

# ── LLM model chains (optional overrides) ─────────────────────────────────────
# Format: provider:model,provider:model,...
# LLM_FAST_CHAIN=groq:llama-3.1-8b-instant,openrouter:google/gemma-4-26b-a4b-it:free
# LLM_MEDIUM_CHAIN=openrouter:google/gemma-4-26b-a4b-it:free,groq:llama-3.3-70b-versatile
# LLM_STRONG_CHAIN=openrouter:anthropic/claude-sonnet-4-6,groq:llama-3.3-70b-versatile

# ── Audit ──────────────────────────────────────────────────────────────────────
AUDIT_LOG_PATH=audit.jsonl
